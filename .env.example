# PostgreSQL connection string (Docker local dev or managed Postgres in prod)
DATABASE_URL=postgres://botdoc:botdoc@localhost:5432/botdoc_lite_reports

# App authentication
APP_PASSWORD=changeme
APP_SESSION_SECRET=change-this-to-a-random-secret

# Admin API key (for protected admin endpoints)
ADMIN_API_KEY=changeme

# Microsoft Fabric SQL endpoint (same server as Connect)
FABRIC_SERVER=your-workspace.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=your-database
FABRIC_TENANT_ID=your-tenant-id
FABRIC_CLIENT_ID=your-client-id
FABRIC_CLIENT_SECRET=your-client-secret

# ------------------------------------------------------------------
# Partner data filter — set this when adding a partner record to the DB.
# For the Botdoc Lite platform: DataFilter = { userIds: [225] }
# For KPA specifically:         DataFilter = { userIds: [221] }
# These are stored per-partner in the partners.data_filter JSONB column,
# not as env vars. Configure them via the admin dashboard.
# ------------------------------------------------------------------
