# ─────────────────────────────────────────────────────────────────────────────
# Botdoc Reports — environment template
#
# This repo hosts TWO products:
#   - Botdoc Connect Reports (/, /customers/...)
#   - Botdoc Lite KPA Reports (/lite, /lite/partners/...)
#
# HOW TO USE:
#   1. Copy this file to `.env`  ->  `cp .env.example .env`
#   2. Fill in the real values in `.env` (NEVER in this file — this one is committed).
#   3. `.env` is gitignored, so secrets never get committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Microsoft Fabric (data source — shared by both products) ────────────────
FABRIC_SERVER=your-endpoint.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=your-warehouse-name
FABRIC_TENANT_ID=00000000-0000-0000-0000-000000000000
FABRIC_CLIENT_ID=00000000-0000-0000-0000-000000000000
FABRIC_CLIENT_SECRET=

# ── PostgreSQL (app database — shared by both products) ─────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/botdoc_reports

# ── Mailgun (Connect email delivery) ───────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=Botdoc Reports <reports@yourdomain.com>
# EU Mailgun accounts only: uncomment the EU base URL (default is US).
# MAILGUN_BASE_URL=https://api.eu.mailgun.net
# Default recipient for `bun run test:mailgun` (or pass one as an arg).
MAILGUN_TEST_TO=

# ── App ─────────────────────────────────────────────────────────────────────
# Base URL for report links in scheduled emails (Connect product).
APP_BASE_URL=http://localhost:3000

# ── Auth (shared by both products) ──────────────────────────────────────────
APP_PASSWORD=
APP_SESSION_SECRET=
# Secret for /api/admin/* and /api/cron/* routes:
ADMIN_API_KEY=
